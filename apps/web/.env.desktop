# Build instalador (`npm run build:installer`). La API embebida fija el origen en 127.0.0.1:4000.
VITE_API_ORIGIN=http://127.0.0.1:4000
VITE_HASH_ROUTER=true
# Solo desarrollo local (Electron contra API en marcha). El instalador para clientes NO incluye estas claves.
# VITE_LOCAL_DEFAULT_EMAIL=studio@radioflow.local
