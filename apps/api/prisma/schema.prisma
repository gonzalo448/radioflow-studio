generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  admin
  editor
  dj
  viewer
}

enum StreamProtocol {
  icecast
  shoutcast
  azuracast
}

enum StationMode {
  AUTO
  LIVE_ASSIST
  LIVE
}

enum PlayAction {
  QUEUE_APPEND
  QUEUE_REMOVE
  SKIP
  STATION_UPDATE
  PLAYLIST_QUEUE_SYNC
  LIBRARY_UPLOAD
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  displayName  String?
  role         Role     @default(viewer)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  playLogs     PlayLog[]
}

model AppSettings {
  id                       String   @id @default("global")
  stationName              String   @default("RadioFlow Studio")
  tagline                  String?
  primaryColor             String?  @default("#38bdf8")
  logoUrl                  String?
  activeStreamingTargetId  String?
  updatedAt                DateTime @updatedAt
}

model MediaAsset {
  id             String          @id @default(cuid())
  title          String
  artist         String?
  album          String?
  path           String
  durationSec    Int?
  mimeType       String?
  embeddingRef   String?
  semanticNote   String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  playlistItems  PlaylistItem[]
  playQueueItems PlayQueueItem[]
  playLogs       PlayLog[]
}

model Playlist {
  id             String          @id @default(cuid())
  name           String
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  items          PlaylistItem[]
  scheduleBlocks ScheduleBlock[]
}

model PlaylistItem {
  id         String   @id @default(cuid())
  playlistId String
  assetId    String
  position   Int
  playlist   Playlist @relation(fields: [playlistId], references: [id], onDelete: Cascade)
  asset      MediaAsset @relation(fields: [assetId], references: [id], onDelete: Cascade)

  @@unique([playlistId, position])
}

model Station {
  id                           String           @id
  mode                         StationMode      @default(AUTO)
  currentPosition              Int              @default(0)
  liveTitle                    String?
  autoScheduleEnabled          Boolean          @default(false)
  lastAppliedScheduleBlockId   String?
  updatedAt                    DateTime         @updatedAt
  queue                        PlayQueueItem[]
}

model PlayQueueItem {
  id        String     @id @default(cuid())
  stationId String     @default("main")
  station   Station    @relation(fields: [stationId], references: [id], onDelete: Cascade)
  position  Int
  assetId   String
  asset     MediaAsset @relation(fields: [assetId], references: [id], onDelete: Cascade)
  createdAt DateTime   @default(now())

  @@unique([stationId, position])
}

model ScheduleBlock {
  id          String    @id @default(cuid())
  label       String
  dayOfWeek   Int
  startMinute Int
  endMinute   Int
  playlistId  String?
  playlist    Playlist? @relation(fields: [playlistId], references: [id], onDelete: SetNull)
  priority    Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model StreamingTarget {
  id             String         @id @default(cuid())
  name           String
  protocol       StreamProtocol
  host           String
  port           Int            @default(8000)
  mountPath      String         @default("/stream")
  sourceUser     String?
  sourcePassword String
  publicBaseUrl  String?
  tls            Boolean        @default(false)
  enabled        Boolean        @default(true)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
}

model PlayLog {
  id        String     @id @default(cuid())
  stationId String     @default("main")
  action    PlayAction
  assetId   String?
  asset     MediaAsset? @relation(fields: [assetId], references: [id], onDelete: SetNull)
  details   Json?
  userId    String?
  user      User?      @relation(fields: [userId], references: [id], onDelete: SetNull)
  createdAt DateTime   @default(now())
}
