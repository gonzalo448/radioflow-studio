# Copia estas variables o enlaza desde la raíz del monorepo:
#   cp ../../.env.example ../../.env
# y duplica en este directorio como `.env` si desarrollas solo la API:
#   cp ../../.env .env
#
# Valores completos: ver `/.env.example` en la raíz de `radioflow-studio`.

DATABASE_URL=postgresql://radioflow:radioflow_dev@localhost:5432/radioflow
# Modo un solo PC (SQLite, sin Postgres): esquema `prisma/standalone`; migraciones al arrancar la API.
# DATABASE_URL=file:./.data/radioflow-local.db
JWT_SECRET=cambiar-en-produccion-minimo-32-caracteres
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d
PORT=4000
# Ver `/.env.example`: BOOTSTRAP_LOCAL_ADMIN crea el primer admin en instalación local.
# BOOTSTRAP_LOCAL_ADMIN=1
# BOOTSTRAP_ADMIN_EMAIL=studio@radioflow.local
# BOOTSTRAP_ADMIN_PASSWORD=Radioflow_local_dev_1
# Redis opcional (rate-limit login/registro distribuido):
# REDIS_URL=redis://localhost:6379
# RATE_LIMIT_AUTH_MAX=30
# RATE_LIMIT_AUTH_WINDOW_SEC=300
# Pedidos públicos POST /api/requests (por IP):
# SONG_REQUEST_MAX_PER_WINDOW=5
# SONG_REQUEST_WINDOW_SEC=900
# Encoder heartbeat → GET /api/streaming/broadcast-status (stale tras ENCODER_HEARTBEAT_STALE_MS):
# ENCODER_HEARTBEAT_STALE_MS=45000
# A7 — fuente Icecast caída (ver raíz .env.example): ICECAST_SOURCE_ALERT_*
# Desktop embebido (B2): API_BACKGROUND_MODE=full + AUDIO_FFMPEG_ENABLED=1 (cola process-jobs / cues)
# API_BACKGROUND_MODE=full
# AUDIO_FFMPEG_ENABLED=1
# AUDIO_FFPROBE_ENABLED=1
# LIBRARY_PROCESS_WORKER_POLL_MS=2500
# Tareas en segundo plano (no HTTP): http-only | maintenance | automation | full
# Desarrollo local: full. Producción con schedule-worker: maintenance.
# API_BACKGROUND_MODE=full
# SHUTDOWN_GRACE_MS=2000
# Parrilla C3 — un solo aplicador (docs/c3-scheduler-consolidated.md):
# SCHEDULE_APPLY_MODE=auto
# Con schedule-worker externo:
# SCHEDULE_APPLY_MODE=worker
# SCHEDULE_WORKER_EXPECTED=1
# INTERNAL_SCHEDULE_POLL_MS=0
# Parrilla sin worker (todo-en-uno; requiere automation o full):
# INTERNAL_SCHEDULE_POLL_MS=20000
# SCHEDULE_REPLACE_QUEUE=0
# SCHEDULER_EVENTS_POLL_MS=2000
#
# Comprobación / sync de duración desde archivo: si los metadatos no traen duración, ffprobe (opcional):
# AUDIO_FFPROBE_ENABLED=1
# FFPROBE_PATH=ffprobe
# Process tracks (v1): medición loudnorm vía ffmpeg → sugerencia/aplicación de playbackGainDb (sin re-encode):
# AUDIO_FFMPEG_ENABLED=1
# FFMPEG_PATH=ffmpeg
# TTS (P2-03): auto | sapi | espeak | edge-tts | piper
# TTS_ENGINE=auto
# TTS_EDGE_VOICE=es-ES-ElviraNeural
# TTS_PIPER_PATH=piper
# TTS_PIPER_MODEL=/ruta/a/voz.onnx
# Redis pub/sub WS multi-réplica (P2-05): misma REDIS_URL que rate-limit
# Worker de cola (misma DATABASE_URL / MEDIA_ROOT que la API): npm run library-process-worker -w @radioflow/api
# LIBRARY_PROCESS_WORKER_POLL_MS=2500
# Rate-limit encolado POST /library/process-jobs: por usuario (heavy vs light BPM) y por IP; ventana común:
# LIBRARY_PROCESS_ENQUEUE_MAX_PER_MIN=30
# LIBRARY_PROCESS_ENQUEUE_LIGHT_KIND_MAX_PER_MIN=80
# LIBRARY_PROCESS_ENQUEUE_IP_MAX_PER_MIN=120
# LIBRARY_PROCESS_ENQUEUE_WINDOW_SEC=60
# Timeout por archivo en jobs ffmpeg trim/transcode (salvo policy.timeoutMsPerAsset):
# LIBRARY_PROCESS_FFMPEG_TIMEOUT_MS=180000
# Borrar jobs terminados más viejos que N días (completed/failed/cancelled). 0 = no borrar por edad.
# LIBRARY_PROCESS_JOB_RETENTION_DAYS=30
# Intervalo en minutos para esa limpieza (0 = desactivar timer en la API).
# LIBRARY_PROCESS_JOB_CLEANUP_INTERVAL_MIN=1440
# Máx. filas borradas por corrida.
# LIBRARY_PROCESS_JOB_CLEANUP_MAX_DELETE=500
# GET /api/library/audio-tools (caché ~1 min). Admins: ?refresh=1 para recomprobar al instante.
#
# Liquidsoap — LEGACY / opt-in (path por defecto = encoder → Icecast, A2).
# Poll in-process (0 = off, recomendado). Solo activar si usás Liquidsoap externo:
# LIQUIDSOAP_M3U_POLL_MS=120000
# LIQUIDSOAP_PLAYLIST_DIR=./playlists
# npm run liquidsoap:gen-m3u
# npm run liquidsoap:cron
# LIQUIDSOAP_CRON_SCHEDULE=0 * * * *
# LIQUIDSOAP_CRON_TZ=America/Bogota
# LIQUIDSOAP_CRON_RUN_ON_START=1
# En Docker: perfiles `liquidsoap` + `liquidsoap-cron` (no arrancan con `up` normal).
# En Docker (perfil liquidsoap-cron): LIQUIDSOAP_PLAYLIST_DIR=/app/playlists
#
# En producción detrás de un dominio único (panel + API vía Nginx), definí la URL base para "Try it out" en Swagger:
# OPENAPI_SERVER_URL=https://studio.tudominio.com
# Origen público para URLs de carátula en GET /api/public/now-playing (sin barra final).
# PUBLIC_API_BASE_URL=https://studio.tudominio.com
# Export sidecar nowplaying.json + current-cover.jpg (default: activo → {MEDIA_ROOT}/nowplaying)
# NOW_PLAYING_EXPORT_ENABLED=1
# NOW_PLAYING_EXPORT_DIR=C:/radioflow/nowplaying
# Bóveda estricta: copy (default, solo upload) | register (POST /library/assets + M3U registrar)
# LIBRARY_INGEST_MODE=copy
# Opcional — E2E admin (cuenta fija en lugar de promoción Prisma):
# E2E_ADMIN_EMAIL=studio@radioflow.local
# E2E_ADMIN_PASSWORD=...
#
# Con TZ: día/hora en esa zona (ej. America/Bogota).
# PROGRAMACION_TZ=America/Bogota
# M3U: GET /api/programacion/actual?format=m3u (rutas como en BD) o &absolute=1 (rutas absolutas MEDIA_ROOT).
