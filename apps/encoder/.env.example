RADIOFLOW_API_URL=http://127.0.0.1:4000
# Misma raíz que MEDIA_ROOT de la API (ruta absoluta en Windows; con Docker dev: apps/api/data/media)
RADIOFLOW_MEDIA_ROOT=C:/Users/gonza/projects/radioflow-studio/apps/api/data/media
# Opción A: URL fija (solo si no hay RADIOFLOW_TOKEN, o con RADIOFLOW_ICECAST_URL_FORCE=1).
# RADIOFLOW_ICECAST_URL=icecast://source:radioflow_dev@127.0.0.1:8840/stream
ENABLE_FFMPEG=1
# No corras este encoder si ya está activo `docker compose ... encoder` o `icecast-hold` (403 = mount /stream ocupado).
# RADIOFLOW_TOKEN=
# Opción B: dejar RADIOFLOW_ICECAST_URL vacío y usar token + destino activo en Marca
# Opción B: dejar vacío y definir RADIOFLOW_TOKEN + destino activo en Marca (panel)
# RADIOFLOW_ICECAST_REFRESH_MS=120000
# Usar WebSocket (por defecto 1). Polling de respaldo si WS cae o RADIOFLOW_USE_WS=0
# RADIOFLOW_USE_WS=1
RADIOFLOW_POLL_MS=15000
# Heartbeat a la API para panel de emisión (requiere RADIOFLOW_TOKEN dj+):
# RADIOFLOW_ENCODER_HEARTBEAT_MS=10000
# ENABLE_FFMPEG=1
#
# --- Estabilidad FFmpeg (ENABLE_FFMPEG=1) ---
# Tras SIGTERM, SIGKILL si el proceso no termina (ms).
# RADIOFLOW_FFMPEG_KILL_AFTER_MS=8000
# Backoff entre reintentos si Icecast/FFmpeg cae (misma pista en cola).
# RADIOFLOW_FFMPEG_RESTART_BASE_MS=2500
# Tras fin normal del archivo (exit 0), pausa antes de repetir la misma pista (sin backoff de error).
# RADIOFLOW_FFMPEG_LOOP_DELAY_MS=800
# Tope de espera entre reintentos (ms).
# RADIOFLOW_FFMPEG_RESTART_MAX_MS=120000
# Máx. reintentos por la misma pista (0 = ilimitado; no recomendado en prod).
# RADIOFLOW_FFMPEG_RESTART_MAX_ATTEMPTS=40
#
# --- Metadatos Icecast admin (E1.4) ---
# Actualiza StreamTitle vía GET /admin/metadata al cambiar pista (misma red que la fuente).
# RADIOFLOW_ICECAST_METADATA=1
# RADIOFLOW_ICECAST_ADMIN_USER=admin
# RADIOFLOW_ICECAST_ADMIN_PASSWORD=radioflow_admin_dev
# Parámetro url= con coverUrl (Icecast KH / reproductores compatibles):
# RADIOFLOW_ICECAST_METADATA_URL=0
