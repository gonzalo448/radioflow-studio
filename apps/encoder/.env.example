RADIOFLOW_API_URL=http://127.0.0.1:4000
# Misma raíz que MEDIA_ROOT de la API (rutas relativas en la BD)
RADIOFLOW_MEDIA_ROOT=../api/data/media
# RADIOFLOW_TOKEN=
# Opción A: URL fija (tiene prioridad sobre la API)
# RADIOFLOW_ICECAST_URL=icecast://source:TU_CLAVE@127.0.0.1:8000/stream
# Opción B: dejar vacío y definir RADIOFLOW_TOKEN + destino activo en Marca (panel)
# RADIOFLOW_ICECAST_REFRESH_MS=120000
# Usar WebSocket (por defecto 1). Polling de respaldo si WS cae o RADIOFLOW_USE_WS=0
# RADIOFLOW_USE_WS=1
RADIOFLOW_POLL_MS=15000
# ENABLE_FFMPEG=1
