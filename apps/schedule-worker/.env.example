RADIOFLOW_API_URL=http://127.0.0.1:4000
# En Docker Compose (perfil workers + servicio api): usar http://api:4000
# RADIOFLOW_API_URL=http://api:4000
# Usuario con rol dj, editor o admin
RADIOFLOW_TOKEN=
# Intervalo de comprobación (ms)
SCHEDULE_POLL_MS=20000
# 1 = reemplazar cola al entrar en un bloque nuevo; 0 = append
# SCHEDULE_REPLACE_QUEUE=1

# C3 — En la API (mismo stack), evita doble apply:
#   SCHEDULE_APPLY_MODE=worker
#   SCHEDULE_WORKER_EXPECTED=1
#   INTERNAL_SCHEDULE_POLL_MS=0
#   API_BACKGROUND_MODE=maintenance
# Ver docs/c3-scheduler-consolidated.md
