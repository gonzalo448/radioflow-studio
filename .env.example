# API (apps/api)
NODE_ENV=development
PORT=4000
DATABASE_URL=postgresql://radioflow:radioflow_dev@localhost:5432/radioflow
JWT_SECRET=cambiar-en-produccion-minimo-32-caracteres
# JWT expiración
# JWT_ACCESS_TTL=15m
# JWT_REFRESH_TTL=30d
# Docker Compose (servicio `api`) puede usar este mismo valor si copias .env a la raíz o exportas JWT_SECRET.
# Incluí todos los orígenes desde los que abrís el Vite (5173 por defecto; 5174 si 5173 estaba ocupado).
# Incluí `null` para la app Electron (origen file://). El default en config.ts ya lo agrega si no definís CORS_ORIGIN.
CORS_ORIGIN=http://localhost:5173,http://127.0.0.1:5173,http://localhost:5174,http://127.0.0.1:5174,null
# Primera instalación (PC local + app escritorio): crea un admin si ese correo aún no existe. Poné 0 en producción expuesta.
BOOTSTRAP_LOCAL_ADMIN=1
BOOTSTRAP_ADMIN_EMAIL=studio@radioflow.local
BOOTSTRAP_ADMIN_PASSWORD=Radioflow_local_dev_1
# Límite global de body JSON (bytes)
# BODY_LIMIT_BYTES=1048576
# Habilita credentials en CORS (true/false)
# CORS_CREDENTIALS=true
# OpenAPI / Swagger UI en /api/docs (default activo). URL pública para "Try it out" si panel y API comparten dominio:
# OPENAPI_SERVER_URL=https://studio.tudominio.com
# OPENAPI_ENABLED=0

# IA semántica (Fase 6)
OLLAMA_BASE_URL=http://localhost:11434
# PERPLEXICA_URL=http://localhost:3001

# Raíz de almacenamiento (relativa al cwd de la API, normalmente apps/api)
MEDIA_ROOT=data/media
# Ingesta a bóveda: copy (default, solo upload) | register (admin: POST /library/assets y M3U registrar)
# LIBRARY_INGEST_MODE=copy
# Escaneo automático de carpetas uploads/ (config en Biblioteca musical → Herramientas)
# LIBRARY_AUTO_UPDATE_POLL_MS=60000
# Opcional: si music-metadata no da duración, la API puede leer con ffprobe (comprobación + sync desde archivo).
# AUDIO_FFPROBE_ENABLED=1
# FFPROBE_PATH=ffprobe
# Procesado tipo "Process tracks" (medición loudnorm, sin re-encode; requiere ffmpeg en PATH o ruta absoluta):
# AUDIO_FFMPEG_ENABLED=1
# FFMPEG_PATH=ffmpeg
# Desktop / instalable (B2): la API embebida fuerza full + FFmpeg/ffprobe + process-jobs por defecto.
# Worker de cola (misma DB y MEDIA_ROOT): npm run dev:library-worker (ver apps/api/.env.example)
# LIBRARY_PROCESS_WORKER_POLL_MS=2500
# Rate-limit encolado process-jobs: usuario (heavy vs light BPM) + IP; ventana:
# LIBRARY_PROCESS_ENQUEUE_MAX_PER_MIN=30
# LIBRARY_PROCESS_ENQUEUE_LIGHT_KIND_MAX_PER_MIN=80
# LIBRARY_PROCESS_ENQUEUE_IP_MAX_PER_MIN=120
# LIBRARY_PROCESS_ENQUEUE_WINDOW_SEC=60
# Pedidos de oyentes (POST /api/requests, por IP):
# SONG_REQUEST_MAX_PER_WINDOW=5
# SONG_REQUEST_WINDOW_SEC=900
# LIBRARY_PROCESS_FFMPEG_TIMEOUT_MS=180000
# Jobs de cola biblioteca: retención (días) e intervalo de limpieza en la API (0 = sin timer o sin borrado por edad).
# LIBRARY_PROCESS_JOB_RETENTION_DAYS=30
# LIBRARY_PROCESS_JOB_CLEANUP_INTERVAL_MIN=1440
# LIBRARY_PROCESS_JOB_CLEANUP_MAX_DELETE=500
# Estado: GET /api/library/audio-tools (probe en caché). Solo admin: ?refresh=1 para recomprobar.

OLLAMA_MODEL=llama3.2
OLLAMA_EMBEDDING_MODEL=nomic-embed-text

# Redis (opcional): rate-limit de /auth en clúster. Ej. redis://localhost:6379
# REDIS_URL=
# RATE_LIMIT_AUTH_MAX=30
# RATE_LIMIT_AUTH_WINDOW_SEC=300

# Limpieza automática de refresh tokens (min). 0 desactiva.
# REFRESH_TOKEN_CLEANUP_INTERVAL_MIN=30
# REFRESH_TOKEN_REVOKED_RETENTION_DAYS=14
# REFRESH_TOKEN_EXPIRED_RETENTION_DAYS=3
# REFRESH_TOKEN_CLEANUP_MAX_DELETE=2000

# Streaming externo — Icecast/Shoutcast/AzuraCast (Fase 4)
# ICECAST_URL=
# ICECAST_SOURCE_PASSWORD=

# Tareas en segundo plano dentro del proceso API (no HTTP). Ver también API_BACKGROUND_MODE.
# Modos: http-only | maintenance | automation | full
# Recomendado desarrollo todo-en-uno: API_BACKGROUND_MODE=full
# Recomendado producción + schedule-worker externo: API_BACKGROUND_MODE=maintenance
# API_BACKGROUND_MODE=full
# SHUTDOWN_GRACE_MS=2000
# SCHEDULER_EVENTS_POLL_MS=2000
# SCHEDULER_EVENTS_RUN_ON_BOOT=1
# ADS_SCHEDULER_POLL_MS=30000
# Playout 24/7 sin UI (modo AUTO): avanza cola por duración si no hay heartbeat del cliente (requiere automation/full)
# HEADLESS_PLAYOUT_POLL_MS=1000
# HEADLESS_PLAYOUT_CLIENT_STALE_MS=12000
# A7 — alerta si Icecast pierde fuente (broadcastEnabled) más de N min:
# ICECAST_SOURCE_ALERT_POLL_MS=60000
# ICECAST_SOURCE_ALERT_AFTER_MS=180000
# ICECAST_SOURCE_ALERT_COOLDOWN_MS=900000
# ICECAST_SOURCE_ALERT_WEBHOOK_URL=https://hooks.example.com/radioflow

# Orquestación de parrilla (elegir UNA opción)
# A) Proceso aparte: npm run dev:schedule con RADIOFLOW_TOKEN + API_BACKGROUND_MODE=maintenance
# B) Dentro de la API (un solo contenedor / sin worker):
# INTERNAL_SCHEDULE_POLL_MS=20000
# SCHEDULE_REPLACE_QUEUE=1
# RADIOFLOW_API_URL=http://127.0.0.1:4000
# RADIOFLOW_TOKEN=<JWT usuario dj / editor / admin>

# Icecast de prueba (Docker profile `broadcast`; alinear con RADIOFLOW_ICECAST_URL del encoder)
# Path al aire por defecto = encoder → Icecast. Liquidsoap = perfiles opt-in `liquidsoap` / `liquidsoap-cron`.
# Puerto publicado en tu PC (dentro del contenedor sigue siendo 8000). Si :8000 está ocupado, usá otro, p. ej. 8840.
# RADIOFLOW_ICECAST_PUBLISH_PORT=8840
# Contraseñas del contenedor (no uses ICECAST_* aquí: en muchas PCs chocan con env global)
# RADIOFLOW_ICECAST_SOURCE_PASSWORD=radioflow_dev
# RADIOFLOW_ICECAST_ADMIN_PASSWORD=radioflow_admin_dev
# RADIOFLOW_ICECAST_RELAY_PASSWORD=radioflow_relay_dev

# Compose prod endurecido:
# POSTGRES_PASSWORD=cambiar-en-produccion
# BOOTSTRAP_LOCAL_ADMIN=0
# CORS_ORIGIN=https://studio.tudominio.com
# API_PORT=4000
# ICECAST_PORT=8000
# Postgres prod: imagen pgvector/pgvector:pg16 (ver docker-compose.prod.yml)
